@page
@using nIKernel.Models.Fornecedor
@model nIKernel.Pages.Fornecedor.IndexModel
@{
    ViewData["Title"] = "Gestão de Fornecedores";

    var claimFornecedores = User.FindFirst(type: "Permissao_Fornecedores")?.Value;
    var permissoes = string.IsNullOrEmpty(claimFornecedores)
        ? new string[] { "N", "N", "N", "N" }
        : claimFornecedores.Split(',');
    bool podeInserir = permissoes.Length > 1 && permissoes[1].Trim().ToUpper() == "S";
    bool podeAtualizar = permissoes.Length > 2 && permissoes[2].Trim().ToUpper() == "S";
    bool podeDeletar = permissoes.Length > 3 && permissoes[3].Trim().ToUpper() == "S";
}

<a href="/" class="btn btn-primary m-2">Voltar para menu</a>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> Fornecedores</h2>

    @if (podeInserir)
    {
        <a asp-page="Criar" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo Fornecedor</a>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nome Fantasia</th>
                    <th>CNPJ</th>
                    <th>E-mail</th>
                    <th width="15%" class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.ListaFornecedores.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 texte-muted">Nenhum fornecedor cadastrado.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.ListaFornecedores)
                    {
                        <tr>
                            <td class="align-middle">@item.NomeFantasia</td>
                            <td class="align-middle">@item.Cnpj</td>
                            <td class="align-middle">@item.Email</td>
                            <td class="acoes">
                                @if (podeAtualizar)
                                {
                                    <a asp-page="Editar" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary me-1 btn-acao"><i class="bi bi-pencil"></i>
                                        Atualizar</a>
                                    }
                                    @if (podeDeletar)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-deletar btn-acao"
                                                data-id="@item.Id" data-nome="@item.NomeFantasia">
                                            <i class="bi bi-trash"></i> Excluir
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

@* Modal de confirmação de exclusão *@ 
<div class="modal fade" id="modalConfirmarExclusao" tabindex="-1" aria-labelledby="modalExclusaoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalExclusaoLabel"> <i class="bi bi-exclamation-triangle"></i>
                    Confirmar Exclusão </h5> <button type="button" class="btn-close btn-close-white"
                                                        data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body"> Deseja excluir o fornecedor <strong id="modalNomeFornecedor"></strong>? <p
                    class="text-muted small mt-2 mb-0"> Esta ação não poderá ser desfeita. </p>
                </div>
                <div class="modal-footer"> <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancelar </button>
                    <form id="formDeletar" method="post"> @Html.AntiForgeryToken() <button type="submit" class="btn btn-danger"> <i class="bi bi-trash"></i> Confirmar Exclusão </button> </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

@section Scripts { <script> document.querySelectorAll('.btn-deletar').forEach(function (btn) { btn.addEventListener('click', function () { var id = this.dataset.id; var nome = this.dataset.nome; document.getElementById('modalNomeFornecedor').textContent = nome; document.getElementById('formDeletar').action = '?handler=Delete&id=' + id; var modal = new bootstrap.Modal( document.getElementById('modalConfirmarExclusao') ); modal.show(); }); }); </script> }