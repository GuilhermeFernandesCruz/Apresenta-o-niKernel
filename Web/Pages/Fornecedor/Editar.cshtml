@page "{id:int}"
@using nIKernel.Models.Fornecedor
@model nIKernel.Pages.Fornecedor.EditarModel
@{
    ViewData["Title"] = "Editar Fornecedor";
}

<br>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-plus"></i> Editar Fornecedor</h2>
    <a asp-page="/Fornecedor/Index" class="btn btn-outline-secondary">Voltar</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Fornecedor.Id" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Fornecedor.NomeFantasia" class="form-label fw-bold">Nome Fantasia (Apelido)</label>
                    <input asp-for="Fornecedor.NomeFantasia" class="form-control" placeholder="Ex: Tech Soluções" />
                    <span asp-validation-for="Fornecedor.NomeFantasia" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Fornecedor.Cnpj" class="form-label fw-bold">CNPJ</label>
                    <input asp-for="Fornecedor.Cnpj" class="form-control" placeholder="00.000.000/0001-00" />
                    <span asp-validation-for="Fornecedor.Cnpj" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Fornecedor.EnderecoCep" class="form-label fw-bold">CEP</label>
                    <input asp-for="Fornecedor.EnderecoCep" class="form-control" />
                    <span asp-validation-for="Fornecedor.EnderecoCep" class="text-danger small"></span>
                </div>
                <div class="col-md-8 mb-3">
                    <label asp-for="Fornecedor.EnderecoLogradouro" class="form-label fw-bold">Logradouro</label>
                    <input asp-for="Fornecedor.EnderecoLogradouro" class="form-control" />
                    <span asp-validation-for="Fornecedor.EnderecoLogradouro" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="Fornecedor.EnderecoNumero" class="form-label fw-bold">Número</label>
                    <input asp-for="Fornecedor.EnderecoNumero" class="form-control" />
                    <span asp-validation-for="Fornecedor.EnderecoNumero" class="text-danger small"></span>
                </div>
                <div class="col-md-5 mb-3">
                    <label asp-for="Fornecedor.EnderecoComplemento" class="form-label fw-bold">Complemento</label>
                    <input asp-for="Fornecedor.EnderecoComplemento" class="form-control" />
                    <span asp-validation-for="Fornecedor.EnderecoComplemento" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Fornecedor.EnderecoBairro" class="form-label fw-bold">Bairro</label>
                    <input asp-for="Fornecedor.EnderecoBairro" class="form-control" />
                    <span asp-validation-for="Fornecedor.EnderecoBairro" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Fornecedor.EnderecoCidade" class="form-label fw-bold">Cidade</label>
                    <input asp-for="Fornecedor.EnderecoCidade" class="form-control" />
                    <span asp-validation-for="Fornecedor.EnderecoCidade" class="text-danger small"></span>
                </div>
                <div class="col-md-2 mb-3">
                    <label asp-for="Fornecedor.EnderecoEstado" class="form-label fw-bold">Estado</label>
                    <input asp-for="Fornecedor.EnderecoEstado" class="form-control" />
                    <span asp-validation-for="Fornecedor.EnderecoEstado" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Fornecedor.Email" class="form-label fw-bold">E-mail de Contato</label>
                    <input asp-for="Fornecedor.Email" type="email" class="form-control" placeholder="exemplo@email.com" />
                    <span asp-validation-for="Fornecedor.Email" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Fornecedor.Telefone" class="form-label fw-bold">Telefone / WhatsApp</label>
                    <input asp-for="Fornecedor.Telefone" class="form-control" placeholder="(00) 00000-0000" />
                    <span asp-validation-for="Fornecedor.Telefone" class="text-danger small"></span>
                </div>
            </div>

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-page="Index" class="btn btn-outline-secondary">Voltar</a>
                <button type="submit" class="btn btn-primary px-4">Atualizar Dados</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/for_cep-autocomplete.js" asp-append-version="true"></script>
}
