@page
@using nIKernel.Models.Fornecedor
@model nIKernel.Pages.Fornecedor.CriarModel
@{
    ViewData["Title"] = "Cadastrar Fornecedor";
}

<br>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-plus"></i> Cadastrar Fornecedor</h2>
    <a asp-page="/Fornecedor/Index" class="btn btn-outline-secondary">Voltar</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold" asp-for="Fornecedor.NomeFantasia">Nome Fantasia</label>
                    <input asp-for="Fornecedor.NomeFantasia" class="form-control" placeholder="Ex: Tech Soluções" />
                    <span asp-validation-for="Fornecedor.NomeFantasia" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold" for="Fornecedor_Cnpj">CNPJ</label>
                    <input asp-for="Fornecedor.Cnpj" class="form-control" placeholder="00.000.000/0001-00" />
                    <span asp-validation-for="Fornecedor.Cnpj" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold" for="Fornecedor_EnderecoCep">CEP</label>
                    <input asp-for="Fornecedor.EnderecoCep" class="form-control" placeholder="00000-000" />
                    <span asp-validation-for="Fornecedor.EnderecoCep" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label class="form-label fw-bold" for="Fornecedor_EnderecoLogradouro">Logradouro</label>
                    <input asp-for="Fornecedor.EnderecoLogradouro" class="form-control" placeholder="Rua, Avenida, Travessa" />
                    <span asp-validation-for="Fornecedor.EnderecoLogradouro" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold" for="Fornecedor_EnderecoNumero">Número</label>
                    <input asp-for="Fornecedor.EnderecoNumero" class="form-control" placeholder="123" />
                    <span asp-validation-for="Fornecedor.EnderecoNumero" class="text-danger small"></span>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold" for="Fornecedor_EnderecoComplemento">Complemento</label>
                    <input asp-for="Fornecedor.EnderecoComplemento" class="form-control" placeholder="Bloco, Apt, Sala" />
                    <span asp-validation-for="Fornecedor.EnderecoComplemento" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold" for="Fornecedor_EnderecoBairro">Bairro</label>
                    <input asp-for="Fornecedor.EnderecoBairro" class="form-control" placeholder="Centro" />
                    <span asp-validation-for="Fornecedor.EnderecoBairro" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold" for="Fornecedor_EnderecoCidade">Cidade</label>
                    <input asp-for="Fornecedor.EnderecoCidade" class="form-control" placeholder="São Paulo" />
                    <span asp-validation-for="Fornecedor.EnderecoCidade" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold" for="Fornecedor_EnderecoEstado">Estado</label>
                    <input asp-for="Fornecedor.EnderecoEstado" class="form-control" placeholder="SP" />
                    <span asp-validation-for="Fornecedor.EnderecoEstado" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold" for="Fornecedor_Email">E-mail</label>
                    <input asp-for="Fornecedor.Email" type="email" class="form-control" placeholder="contato@empresa.com" />
                    <span asp-validation-for="Fornecedor.Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold" for="Fornecedor_Telefone">Telefone</label>
                    <input asp-for="Fornecedor.Telefone" class="form-control" placeholder="(00) 90000-0000" />
                    <span asp-validation-for="Fornecedor.Telefone" class="text-danger small"></span>
                </div>

                <div class="col-12 d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-primary px-5">Salvar Fornecedor</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/for_cep-autocomplete.js" asp-append-version="true"></script>
}
