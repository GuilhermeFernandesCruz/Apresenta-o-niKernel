@page
@model Web.Pages.Categorias.IndexModel
@{
    ViewData["Title"] = "Categorias";
      var claimClientes = User.FindFirst(type: "Permissao_Categorias")?.Value;
    var permissoes = string.IsNullOrEmpty(claimClientes)
            ? new string[] { "N", "N", "N", "N" }
        : claimClientes.Split(',');    
    bool podeInserir = permissoes.Length > 1 && permissoes[1].Trim().ToUpper() == "S";
    bool podeAtualizar = permissoes.Length > 2 && permissoes[2].Trim().ToUpper() == "S";
    bool podeDeletar = permissoes.Length > 3 && permissoes[3].Trim().ToUpper() == "S";
}

<br>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tags"></i> Categorias Registradas</h2>
    @if (podeInserir)
    {
        <a asp-page="/Categorias/Criar" class="btn btn-primary">Nova Categoria</a>
    }
</div>

<div class="card shadow-sm">
<div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Descrição</th>
                    <th>Status</th>
                    <th width="15%" class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Categorias.Any()) {
                <tr>
                    <td colspan="6" class="text-center py-4 texte-muted">Nenhuma categoria cadastrada.</td>
                </tr>
            } else {
                foreach (var categoria in Model.Categorias) {
                    <tr>
                        <td class="align-middle">@categoria.ctg_id</td>
                        <td class="align-middle">@categoria.ctg_dcc</td>
                        <td class="align-middle">
                            @if (categoria.ctg_sta == "S") {
                                <span class="badge bg-success">Ativo</span>
                            } else {
                                <span class="badge bg-secondary">Inativo</span>
                            }
                        </td>
                        <td class="acoes">
                            @if (podeAtualizar) {
                                <a asp-page="Editar" asp-route-id="@categoria.ctg_id" class="btn btn-sm btn-outline-primary me-1 btn-acao"><i class="bi bi-pencil"></i> Atualizar</a>
                            }
                            @if (podeDeletar && categoria.ctg_sta == "S") {
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger btn-deletar btn-acao"
                                        data-id="@categoria.ctg_id"
                                        data-descricao="@categoria.ctg_dcc">
                                    <i class="bi bi-trash"></i> Excluir
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    </div>
</div>
