@page
@using Microsoft.AspNetCore.Http.Features
@model nIKernel.Pages.Admin.Perfis.IndexModel
@{
    ViewData["Title"] = "Gerenciar Perfis";

    var claimPerfils = User.FindFirst(type: "Permissao_Perfis")?.Value;
    var permissoes = string.IsNullOrEmpty(claimPerfils)
        ? new string[] { "N", "N", "N", "N" }
    : claimPerfils.Split(',');
    bool podeInserir = permissoes.Length > 1 && permissoes[1].Trim().ToUpper() == "S";
    bool podeAtualizar = permissoes.Length > 2 && permissoes[2].Trim().ToUpper() == "S";
    bool podeDeletar = permissoes.Length > 3 && permissoes[3].Trim().ToUpper() == "S";
}

<a href="/" class="btn btn-primary m-2">Voltar para menu</a>
@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-shield-lock"></i> Perfis de Acesso</h2>

    @if (podeInserir)
    {
        <a asp-page="Criar" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo Perfil</a>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th width="10%">ID</th>
                    <th> Descrição do Perfil</th>
                    @using nIKernel.Models.Perfil
                <th width="15%" class="text-center">Status</th>
                <th width="20%" class="text-end">Ações</th>
</tr>
            </thead>
            <tbody>
                @if (!Model.Perfis.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 texte-muted">Nenhum perfil cadastrado.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Perfis)
                    {
                        <tr>
                            <td class="align-middle">@item.PRF_ID</td>
                            <td class="align-middle fw-bold">@item.PRF_DSC</td>
                            <td class="align-middle text-center">
                                @if (item.PRF_STA == "A")
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inativo</span>
                                }
                            </td>
                            <td class="acoes">
                                @if (podeAtualizar)
                                {
                                    <a asp-page="Editar" asp-route-id="@item.PRF_ID"
                                       class="btn btn-sm btn-outline-primary btn-acao"><i class="bi bi-pencil"></i> Atualizar </a>
                                }
                                @if (podeDeletar)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger ms-1 btn-deletar btn-acao"
                                            data-id="@item.PRF_ID" data-descricao="@item.PRF_DSC"> <i class="bi bi-trash"></i> Deletar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

@* Modal de confirmação de exclusão *@ 
<div class="modal fade" id="modalConfirmarExclusao" tabindex="-1" aria-labelledby="modalExclusaoLabel" aria-hidden="true">
<div class="modal-dialog modal-dialog-centered">
<div class="modal-content">
    <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="modalExclusaoLabel"> <i class="bi bi-exclamation-triangle"></i>
            Confirmar Exclusão </h5> <button type="button" class="btn-close btn-close-white"
                                                data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body"> Deseja inativar o perfil <strong id="modalNomePerfil"></strong>? <p
            class="text-muted small mt-2 mb-0"> O perfil será marcado como inativo e não poderá ser
            utilizado em novas operações. </p>
        </div>
        <div class="modal-footer"> <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Cancelar </button>
            <form id="formDeletar" method="post"> <button type="submit" class="btn btn-danger"> <i
                class="bi bi-trash"></i> Confirmar Exclusão </button> </form>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script> document.querySelectorAll('.btn-deletar').forEach(function (btn) { btn.addEventListener('click', function () { var id = this.dataset.id; var descricao = this.dataset.descricao; document.getElementById('modalNomePerfil').textContent = descricao; document.getElementById('formDeletar').action = '?handler=Deletar&id=' + id; var modal = new bootstrap.Modal(document.getElementById('modalConfirmarExclusao')); modal.show(); }); }); </script>
}