@page "{id:int}"
@using Web.Models.Produto
@model Web.Pages.Admin.Produtos.EditarModel
@{
    ViewData["Title"] = "Editar Produto";
}

<br>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Editar Produto</h2>
    <a asp-page="/Produtos/Index" class="btn btn-outline-secondary">Voltar</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <form method="post">
            <input type="hidden" asp-for="Produto.prd_id" />
            <input type="hidden" asp-for="Produto.prd_data_criacao" />

            <div class="row">
                <div class="col-md-6">
                    <label asp-for="Produto.prd_cod" class="form-label fw-bold">Código</label>
                    <input asp-for="Produto.prd_cod" class="form-control" placeholder="Código interno" />
                    <span asp-validation-for="Produto.prd_cod" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Produto.prd_gtin_ean" class="form-label fw-bold">GTIN/EAN</label>
                    <input asp-for="Produto.prd_gtin_ean" class="form-control" maxlength="14" placeholder="Somente dígitos" />
                    <span asp-validation-for="Produto.prd_gtin_ean" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Produto.prd_descricao" class="form-label fw-bold">Descrição</label>
                <input asp-for="Produto.prd_descricao" class="form-control" placeholder="Descrição do produto" />
                <span asp-validation-for="Produto.prd_descricao" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Produto.prd_ctg_id" class="form-label fw-bold">Categoria</label>
                <select asp-for="Produto.prd_ctg_id" class="form-select">
                    <option value="">-- Selecione --</option>
                    @foreach (var c in (IEnumerable<Web.Models.Categoria.CtgCategoriaModel>)ViewData["Categorias"])
                    {
                        <option value="@c.ctg_id" selected="@(Model.Produto.prd_ctg_id == c.ctg_id ? "selected" : null)">@c.ctg_dcc</option>
                    }
                </select>
                <span asp-validation-for="Produto.prd_ctg_id" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label asp-for="Produto.prd_un_compra" class="form-label fw-bold">Unidade de Compra</label>
                    <select asp-for="Produto.prd_un_compra" class="form-select">
                        <option value="UN">Unidade</option>
                        <option value="CX">Caixa</option>
                        <option value="KG">Quilo</option>
                        <option value="G">Grama</option>
                        <option value="LT">Litro</option>
                    </select>
                    <span asp-validation-for="Produto.prd_un_compra" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Produto.prd_un_venda" class="form-label fw-bold">Unidade de Venda</label>
                    <select asp-for="Produto.prd_un_venda" class="form-select">
                        <option value="UN">Unidade</option>
                        <option value="CX">Caixa</option>
                        <option value="KG">Quilo</option>
                        <option value="G">Grama</option>
                        <option value="LT">Litro</option>
                    </select>
                    <span asp-validation-for="Produto.prd_un_venda" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Produto.prd_preco_compra" class="form-label fw-bold">Preço de Compra</label>
                    <input asp-for="Produto.prd_preco_compra" class="form-control" type="number" step="0.01" min="0" />
                    <small class="form-text text-muted">Use ponto para decimais.</small>
                    <span asp-validation-for="Produto.prd_preco_compra" class="text-danger small"></span>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-6">
                    <label asp-for="Produto.prd_margem_venda" class="form-label fw-bold">Margem de Lucro (%)</label>
                    <input asp-for="Produto.prd_margem_venda" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Produto.prd_margem_venda" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Produto.prd_ativo" class="form-label fw-bold">Ativo</label>
                    <select asp-for="Produto.prd_ativo" class="form-select">
                        <option value="S">Sim</option>
                        <option value="N">Não</option>
                    </select>
                    <span asp-validation-for="Produto.prd_ativo" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <button type="submit" class="btn btn-primary px-4">Salvar Alterações</button>
                <a asp-page="Index" class="btn btn-outline-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
