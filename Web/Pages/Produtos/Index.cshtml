@page
@using Web.Models.Produto
@model Web.Pages.Admin.Produtos.IndexModel
@{
    ViewData["Title"] = "Produtos";

    var claimProdutos = User.FindFirst(type: "Permissao_Produtos")?.Value;
    var permissoes = string.IsNullOrEmpty(claimProdutos)
        ? new string[] { "N", "N", "N", "N" }
        : claimProdutos.Split(',');
    bool podeInserir = permissoes.Length > 1 && permissoes[1].Trim().ToUpper() == "S";
    bool podeAtualizar = permissoes.Length > 2 && permissoes[2].Trim().ToUpper() == "S";
    bool podeDeletar = permissoes.Length > 3 && permissoes[3].Trim().ToUpper() == "S";
}

<a href="/" class="btn btn-primary m-2">Voltar para menu</a>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Produtos</h2>

    <div class="d-flex gap-2">
        @if (Model.ApenasAtivos) {
            <a asp-page="Index" asp-route-apenasAtivos="false" class="btn btn-outline-secondary">
                <i class="bi bi-eye"></i> Exibir Inativos
            </a>
        } else {
            <a asp-page="Index" asp-route-apenasAtivos="true" class="btn btn-secondary">
                <i class="bi bi-eye-slash"></i> Ocultar Inativos
            </a>
        }
        @if (podeInserir) {
            <a asp-page="Criar" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo Produto</a>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Descrição</th>
                    <th>GTIN/EAN</th>
                    <th>Preço Venda</th>
                    <th>Ativo</th>
                    <th width="15%" class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Produtos.Any()) {
                <tr>
                    <td colspan="6" class="text-center py-4 texte-muted">Nenhum produto cadastrado.</td>
                </tr>
            } else {
                foreach (var produto in Model.Produtos) {
                    <tr>
                        <td class="align-middle">@produto.prd_cod</td>
                        <td class="align-middle">@produto.prd_descricao</td>
                        <td class="align-middle">@produto.prd_gtin_ean</td>
                        <td class="align-middle">@produto.prd_preco_venda.ToString("C")</td>
                        <td class="align-middle">
                            @if (produto.prd_ativo == "S") {
                                <span class="badge bg-success">Ativo</span>
                            } else {
                                <span class="badge bg-secondary">Inativo</span>
                            }
                        </td>
                        <td class="acoes">
                            @if (podeAtualizar) {
                                <a asp-page="Editar" asp-route-id="@produto.prd_id" class="btn btn-sm btn-outline-primary me-1 btn-acao"><i class="bi bi-pencil"></i> Atualizar</a>
                            }
                            @if (podeDeletar && produto.prd_ativo == "S") {
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger btn-deletar btn-acao"
                                        data-id="@produto.prd_id"
                                        data-descricao="@produto.prd_descricao">
                                    <i class="bi bi-trash"></i> Excluir
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

@* Modal de confirmação de exclusão *@
<div class="modal fade" id="modalConfirmarExclusao" tabindex="-1" aria-labelledby="modalExclusaoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalExclusaoLabel"><i class="bi bi-exclamation-triangle"></i> Confirmar Exclusão</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Deseja inativar o produto <strong id="modalNomeProduto"></strong>?
                <p class="text-muted small mt-2 mb-0">O produto será marcado como inativo e não aparecerá em novas operações.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="formDeletar" method="post">
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Confirmar Exclusão</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.btn-deletar').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var id = this.dataset.id;
            var descricao = this.dataset.descricao;
            document.getElementById('modalNomeProduto').textContent = descricao;
            document.getElementById('formDeletar').action = '?handler=Deletar&id=' + id;
            var modal = new bootstrap.Modal(document.getElementById('modalConfirmarExclusao'));
            modal.show();
        });
    });
</script>
}
