@page
@using nIKernel.Models.Cliente
@model nIKernel.Pages.Clientes.IndexModel

@{
    ViewData["Title"] = "Gerenciar Clientes";
    
    var claimClientes = User.FindFirst(type: "Permissao_Clientes")?.Value;
    var permissoes = string.IsNullOrEmpty(claimClientes)
            ? new string[] { "N", "N", "N", "N" }
        : claimClientes.Split(',');    
    bool podeInserir = permissoes.Length > 1 && permissoes[1].Trim().ToUpper() == "S";
    bool podeAtualizar = permissoes.Length > 2 && permissoes[2].Trim().ToUpper() == "S";
    bool podeDeletar = permissoes.Length > 3 && permissoes[3].Trim().ToUpper() == "S";
}


<a href="/" class="btn btn-primary m-2">Voltar para menu</a>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-shield-lock"></i>Clientes Registrados</h2>

    <div class="d-flex gap-2">
        @if (Model.ApenasAtivos) {
            <a asp-page="Index" asp-route-apenasAtivos="false" class="btn btn-outline-secondary">
                <i class="bi bi-eye"></i> Exibir Inativos
            </a>
        } else {
            <a asp-page="Index" asp-route-apenasAtivos="true" class="btn btn-secondary">
                <i class="bi bi-eye-slash"></i> Ocultar Inativos
            </a>
        }
        @if (podeInserir) {
            <a asp-page="Criar" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo Cliente</a>
        }
    </div>
</div>


<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                        <th width="5%">ID</th>
                        <th>CPF/CNPJ</th>
                        <th>RG/IE</th>
                        <th>Nome</th>
                        <th>Apelido</th>
                        <th  width="15%" class="text-center">Status</th>
                        <th>Data de inclusão</th>
                        <th width="15%" class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Clientes.Any()) {
                    <tr>
                        <td colspan="4" class="text-center py-4 texte-muted">Nenhum cliente cadastrado.</td>
                    </tr>
                } else {
                    foreach (var cliente in Model.Clientes) {
                        <tr>
                            <td class="align-middle">@cliente.CL_id</td>
                            <td class="align-middle">@cliente.CL_cpf_cnpj</td>
                            <td class="align-middle">@cliente.CL_rg_ie</td>
                            <td class="align-middle">@cliente.CL_nome</td>
                            <td class="align-middle">@cliente.CL_apelido</td>
                            <td class="align-middle text-center">
                                @if (cliente.CL_status == "A") {
                                    <span class="badge bg-success">Ativo</span>
                                } else if (cliente.CL_status == "I") {
                                    <span class="badge bg-secondary">Inativo</span>
                                } else {
                                    <span class="badge bg-danger">Bloqueado</span>
                                }
                            </td> 
                            <td class="align-middle">@cliente.CL_data_inclusao</td>
                            <td class="acoes">
                                @if (podeAtualizar) {
                                    <a asp-page="Editar" asp-route-id="@cliente.CL_id" class="btn btn-sm btn-outline-primary btn-acao"><i class="bi bi-pencil"></i> Atualizar </a>
                                }
                                @if (podeDeletar && cliente.CL_status == "A") {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger ms-1 btn-deletar btn-acao"
                                            data-id="@cliente.CL_id"
                                            data-nome="@cliente.CL_nome">
                                        <i class="bi bi-trash"></i> Excluir
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>


@* Modal de confirmação de exclusão *@
<div class="modal fade" id="modalConfirmarExclusao" tabindex="-1" aria-labelledby="modalExclusaoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalExclusaoLabel">
                    <i class="bi bi-exclamation-triangle"></i>
                    Confirmar Exclusão
                </h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Deseja excluir o cliente
                <strong id="modalNomeCliente"></strong>?
                <p class="text-muted small mt-2 mb-0">
                    Todos os endereços vinculados a este cliente também serão removidos.
                    Esta ação não poderá ser desfeita.
                </p>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <form id="formDeletar" method="post">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i>
                        Confirmar Exclusão
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.btn-deletar').forEach(function (btn) {

        btn.addEventListener('click', function () {

            var id = this.dataset.id;
            var nome = this.dataset.nome;

            document.getElementById('modalNomeCliente').textContent = nome;

            document.getElementById('formDeletar').action =
                '?handler=Deletar&id=' + id;

            var modal = new bootstrap.Modal(
                document.getElementById('modalConfirmarExclusao')
            );

            modal.show();
        });

    });
</script>
}